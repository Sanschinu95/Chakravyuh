# Copy to .env and fill in. .env is gitignored -- never commit real keys.

# --- LLM provider -----------------------------------------------------------
# Groq is the default. Used for solver narration, tender cover notes, news
# event extraction, and the red team agent's tool-use loop.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FAST_MODEL=llama-3.3-70b-versatile

# Alternative provider. If both are set, LLM_PROVIDER decides.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# groq | anthropic
LLM_PROVIDER=groq

# --- Live vessel feed (optional) --------------------------------------------
# Without this, AIS is served from the replay archive and is labelled REPLAY.
# It can never be labelled LIVE unless a real key is present.
# Get one at https://aisstream.io
AISSTREAM_API_KEY=

# Everything runs without any key at all: the LLM falls back to deterministic
# templates and says so in the UI.
